#!/usr/bin/make -f
#export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_install:
	mkdir debian/truenas
	cp -aR data etc usr debian/truenas/

override_dh_installsystemd:
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-boot-core
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-cgroups
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-dhcpcd@
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-etc
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-netif
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-postinit
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-preinit
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-reboot
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-reporting
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-shutdown
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-ssh-keys
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-syncdisks
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-upsshutdown
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-vendor
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-wait-on-disks
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas-zfs
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=snmp-agent
	dh_installsystemd --no-start -r --no-restart-after-upgrade --name=xnas
